LANGFLOW_API_URL=
LANGFLOW_FLOW_ID=
LANGFLOW_API_KEY=

FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_WEB_API_KEY=

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://pitmind:pitmind@localhost:5432/pitmind
OPEN_PIT_WALL_HOME=./data/replay
