# Copy this file to .env and fill only the values required for your setup.
# Never commit .env files.

# Application
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
RATE_LIMIT_PER_MINUTE=120

# IBM watsonx.ai and Granite
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_API_KEY=
WATSONX_MODEL_ID=ibm/granite-3-1-8b-instruct

# Optional Langflow orchestration
LANGFLOW_API_URL=
LANGFLOW_FLOW_ID=
LANGFLOW_API_KEY=

# Optional alternative AI providers
HF_API_TOKEN=
HF_MODEL_ID=ibm-granite/granite-3.1-8b-instruct
REPLICATE_API_TOKEN=
REPLICATE_MODEL_OWNER=
REPLICATE_MODEL_NAME=

# Firebase authentication and realtime race-state sync
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_WEB_API_KEY=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_WEB_API_KEY=

# Browser-facing endpoints
# Leave VITE_API_BASE_URL empty for Docker: Nginx proxies /api to the backend.
# For local Vite development, use http://127.0.0.1:8000.
VITE_API_BASE_URL=
VITE_WS_URL=
VITE_BYPASS_AUTH=false

# PostgreSQL and Redis
POSTGRES_DB=pitmind
POSTGRES_USER=pitmind
POSTGRES_PASSWORD=
REDIS_PASSWORD=
DATABASE_URL=
REDIS_URL=
REDIS_MAX_CONNECTIONS=50

# Integrated historical replay utility
# Replay cache files are written below this directory.
OPEN_PIT_WALL_HOME=/data/replay
REPLAY_DATA_FILE=/data/replay/computed_data/replay.json
REPLAY_SPEED=1.0

# Optional frontend integrations
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
VITE_GA_MEASUREMENT_ID=
